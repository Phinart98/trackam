# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Your deployed Spring Boot backend (Cloud Run URL in production, localhost for dev)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Supabase project — find these in Supabase Dashboard → Settings → API
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_your-anon-key
