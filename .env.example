# Supabase (get from supabase.com → Project Settings → API)
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Spring Boot backend (Cloud Run URL — set when backend is deployed)
# Leave empty to use mock AI (Stage 2 mode)
NUXT_PUBLIC_API_BASE_URL=
